---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Über"
  description="Über Hakan — der Fotograf hinter iamguer.com. Persönliche Bildwelt aus Marburg und unterwegs."
  currentPath="/ueber"
  ogType="profile"
>
  <section class="px-7 py-16 max-w-4xl mx-auto">
    <h1 class="text-text-primary text-5xl md:text-6xl tracking-tight font-light">Hallo. Ich bin Hakan.</h1>
    <p class="text-text-secondary mt-4">
      Bilder aus Marburg und überall sonst — Licht, Schatten, leise Momente.
    </p>
  </section>
</BaseLayout>
