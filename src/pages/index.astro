---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout currentPath="/">
  <section class="px-7 py-24">
    <h1
      class="font-serif text-text-primary text-7xl md:text-9xl tracking-tight leading-none"
    >
      guer<span class="text-accent">.</span>
    </h1>
    <p
      class="font-serif text-text-secondary text-lg mt-6 max-w-md leading-relaxed"
    >
      Bilder aus Marburg und überall sonst — in voller Auflösung, mit Raum zum
      Atmen.
    </p>
  </section>
</BaseLayout>
