---
import BrandMark from './BrandMark.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: '/', label: 'Index' },
  { href: '/galerien', label: 'Galerien' },
  { href: '/kontakt', label: 'Kontakt' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<nav class="flex justify-between items-center px-7 py-5 border-b border-line">
  <a href="/" class="text-lg tracking-tight text-text-primary">
    <BrandMark />
  </a>

  <ul class="hidden md:flex items-center gap-8 font-mono text-xs uppercase tracking-widest">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'transition-colors hover:text-text-primary',
              isActive(link.href) ? 'text-text-primary' : 'text-text-muted',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <button
    type="button"
    id="navMobileToggle"
    aria-label="Menü öffnen"
    aria-expanded="false"
    aria-controls="navMobileMenu"
    class="md:hidden flex flex-col items-end justify-center gap-1.5 min-w-[44px] min-h-[44px]"
  >
    <span class="block h-px w-[18px] bg-text-primary"></span>
    <span class="block h-px w-[18px] bg-text-primary"></span>
    <span class="block h-px w-[18px] bg-text-primary"></span>
  </button>
</nav>

<div
  id="navMobileMenu"
  hidden
  aria-hidden="true"
  class="md:hidden fixed inset-0 z-50 bg-canvas flex flex-col"
>
  <div class="flex justify-between items-center px-7 py-5 border-b border-line">
    <span class="text-lg tracking-tight text-text-primary">iamguer</span>
    <button
      type="button"
      id="navMobileClose"
      aria-label="Menü schließen"
      class="min-w-[44px] min-h-[44px] flex items-center justify-center text-text-primary text-3xl leading-none"
    >
      <span aria-hidden="true">×</span>
    </button>
  </div>
  <ul class="flex flex-col px-7 py-12 gap-2 font-mono text-base uppercase tracking-widest">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block min-h-[44px] py-3 transition-colors hover:text-text-primary',
              isActive(link.href) ? 'text-text-primary' : 'text-text-muted',
            ]}
            data-nav-mobile-link
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<style>
  #navMobileMenu {
    opacity: 0;
    transition: opacity 200ms ease;
  }
  #navMobileMenu.is-open {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    #navMobileMenu {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.getElementById('navMobileToggle');
    var menu = document.getElementById('navMobileMenu');
    var closeBtn = document.getElementById('navMobileClose');
    if (!toggle || !menu) return;

    var reduceMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    function open() {
      menu.hidden = false;
      // Force reflow before adding the open class so the fade transition runs.
      void menu.offsetHeight;
      menu.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
      menu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      if (closeBtn) closeBtn.focus();
    }

    function close() {
      menu.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      var delay = reduceMotion ? 0 : 200;
      setTimeout(function () {
        menu.hidden = true;
      }, delay);
      toggle.focus();
    }

    toggle.addEventListener('click', open);
    if (closeBtn) closeBtn.addEventListener('click', close);

    var links = menu.querySelectorAll('[data-nav-mobile-link]');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', close);
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !menu.hidden) close();
    });
  })();
</script>
