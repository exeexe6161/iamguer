---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Splash from '../../components/Splash.astro';
import PreviewSwitcher from '../../components/PreviewSwitcher.astro';
import { loadInstagramPosts, displaySrc, shortCaption } from '../../lib/instagram';

const payload = loadInstagramPosts();
const allPosts = payload?.posts ?? [];
const hero = allPosts[0];
const gridPosts = allPosts.slice(1, 10);

const dateFmt = new Intl.DateTimeFormat('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const heroSrc = hero ? displaySrc(hero) : '/splash/portrait-pool.jpg';
const heroCaption = hero ? shortCaption(hero.caption, 200) : '';
const heroDate = hero ? dateFmt.format(new Date(hero.timestamp)) : '';
const heroPermalink = hero?.permalink;
---

<BaseLayout
  title="Preview — Editorial"
  description="Vorschau Konzept 2: Editorial Bold"
  currentPath="/preview/editorial"
  noIndex={true}
>
  <Fragment slot="head-extra">
    <script is:inline>
      (function () {
        try {
          var url = new URL(window.location.href);
          var skip = url.searchParams.get('skip') === '1';
          var seen = sessionStorage.getItem('iamguer_splash_seen') === '1';
          if (skip || seen) {
            document.documentElement.classList.add('splash-skip');
          } else {
            document.documentElement.classList.add('splash-show');
          }
        } catch (e) {
          document.documentElement.classList.add('splash-show');
        }
      })();
    </script>
    <link
      rel="preload"
      href="/splash/portrait-pool.avif"
      as="image"
      type="image/avif"
      fetchpriority="high"
    />
  </Fragment>

  <Splash />
  <PreviewSwitcher current="editorial" />

  <section class="editorial-hero">
    <div class="hero-photo">
      {heroPermalink ? (
        <a
          href={heroPermalink}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={heroCaption || 'Foto auf Instagram öffnen'}
        >
          <img
            src={heroSrc}
            alt={heroCaption || 'Fotografie von Hakan / iamguer'}
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </a>
      ) : (
        <img
          src={heroSrc}
          alt="Fotografie von Hakan / iamguer"
          loading="eager"
          decoding="async"
        />
      )}
    </div>

    <div class="hero-type">
      <div class="type-stack">
        <h1 class="type-mega">iamguer</h1>
        <p class="type-tagline">Stille Stunden.<br />Lange Schatten.</p>
      </div>

      {heroCaption && (
        <figcaption class="hero-cap">
          <p class="hero-cap-text">{heroCaption}</p>
          <p class="hero-cap-date">{heroDate}</p>
        </figcaption>
      )}
    </div>
  </section>

  <section class="editorial-statement reveal">
    <h2 class="statement-headline">Aufnahmen aus Marburg und unterwegs</h2>
  </section>

  {
    gridPosts.length > 0 ? (
      <section class="editorial-grid reveal">
        <ul>
          {gridPosts.map((post) => (
            <li>
              <a
                href={post.permalink}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={shortCaption(post.caption, 80) || 'Fotografie von Hakan / iamguer'}
              >
                <img
                  src={displaySrc(post)}
                  alt={shortCaption(post.caption, 120) || 'Fotografie von Hakan / iamguer'}
                  title={dateFmt.format(new Date(post.timestamp))}
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </li>
          ))}
        </ul>
      </section>
    ) : (
      <section class="editorial-empty reveal">
        <p>Bilder werden geladen, sobald die Instagram-Synchronisation lief.</p>
      </section>
    )
  }

  <section class="editorial-cta reveal">
    <a href="/galerien" class="cta-link">
      Alle Bilder ansehen
      <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>

<style>
  .editorial-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    min-height: 100dvh;
    background: var(--color-canvas);
  }

  .hero-photo {
    position: relative;
    overflow: hidden;
    background: var(--color-tile);
  }

  .hero-photo a,
  .hero-photo img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-photo img {
    object-fit: cover;
    object-position: center;
  }

  .hero-type {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 48px 56px;
    background: var(--color-canvas);
  }

  .type-stack {
    margin: auto 0;
  }

  .type-mega {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 100;
    font-size: clamp(80px, 15vw, 240px);
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: var(--color-text-primary);
    margin: 0;
  }

  .type-tagline {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 200;
    font-size: clamp(20px, 2.5vw, 32px);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text-secondary);
    margin: 32px 0 0 0;
  }

  .hero-cap {
    position: absolute;
    right: 56px;
    bottom: 48px;
    max-width: 32ch;
    text-align: right;
    margin: 0;
  }

  .hero-cap-text {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 300;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0 0 6px 0;
  }

  .hero-cap-date {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Statement */
  .editorial-statement {
    padding: 200px 24px 120px;
    text-align: center;
    background: var(--color-canvas);
  }

  .statement-headline {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 200;
    font-size: clamp(48px, 9vw, 160px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    color: var(--color-text-primary);
    margin: 0 auto;
    max-width: 14ch;
  }

  /* Grid */
  .editorial-grid {
    padding: 0 24px 120px;
    background: var(--color-canvas);
  }

  .editorial-grid ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    max-width: 1600px;
    margin-inline: auto;
  }

  .editorial-grid li {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-tile);
  }

  .editorial-grid a,
  .editorial-grid img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .editorial-grid img {
    object-fit: cover;
    transition: filter 400ms ease;
  }

  .editorial-grid a:hover img,
  .editorial-grid a:focus-visible img {
    filter: brightness(1.1);
  }

  .editorial-empty {
    padding: 120px 24px;
    text-align: center;
    color: var(--color-text-muted);
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 300;
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  /* CTA */
  .editorial-cta {
    padding: 200px 24px;
    text-align: center;
    background: var(--color-canvas);
  }

  .cta-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 200;
    font-size: clamp(36px, 6vw, 96px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .cta-link:hover,
  .cta-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 8px;
    text-decoration-thickness: 1px;
    outline: none;
  }

  /* Reveal */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 800ms cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 800ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .editorial-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-photo {
      aspect-ratio: 3 / 4;
      height: auto;
    }

    .hero-type {
      padding: 56px 24px 80px;
    }

    .hero-cap {
      position: static;
      margin-top: 40px;
      max-width: none;
      text-align: left;
    }

    .editorial-statement {
      padding: 120px 20px 80px;
    }

    .editorial-grid {
      padding: 0 16px 80px;
    }

    .editorial-grid ul {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .editorial-cta {
      padding: 120px 20px;
    }
  }

  @media (max-width: 540px) {
    .editorial-grid ul {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .editorial-grid img {
      transition: none;
    }
    .reveal {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var revealNodes = document.querySelectorAll('.reveal');
    if (!revealNodes.length) return;
    if (!('IntersectionObserver' in window)) {
      revealNodes.forEach(function (n) { n.classList.add('is-visible'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    revealNodes.forEach(function (n) { io.observe(n); });
  })();
</script>
