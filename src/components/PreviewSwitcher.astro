---
interface Props {
  current: 'cinematic' | 'editorial' | 'bento';
}

const { current } = Astro.props;

const variants = [
  { id: 'cinematic', href: '/preview/cinematic', label: '1 — Cinematic' },
  { id: 'editorial', href: '/preview/editorial', label: '2 — Editorial' },
  { id: 'bento', href: '/preview/bento', label: '3 — Bento' },
] as const;
---

<aside class="preview-switcher" aria-label="Preview-Varianten">
  <ul>
    {
      variants.map((v) => (
        <li>
          <a
            href={v.href}
            aria-current={current === v.id ? 'page' : undefined}
            class:list={['pill', current === v.id ? 'is-active' : '']}
          >
            {v.label}
          </a>
        </li>
      ))
    }
  </ul>
</aside>

<style>
  .preview-switcher {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 60;
    pointer-events: none;
  }

  .preview-switcher ul {
    list-style: none;
    margin: 0;
    padding: 6px;
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    justify-content: flex-end;
    background: rgba(15, 15, 15, 0.78);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    pointer-events: auto;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    border-radius: 999px;
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.01em;
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1px solid transparent;
    transition: color 200ms ease, background 200ms ease, border-color 200ms ease;
    white-space: nowrap;
  }

  .pill:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.04);
  }

  .pill.is-active {
    color: var(--color-text-primary);
    background: var(--color-elevated);
    border-color: var(--color-line-strong);
  }

  @media (max-width: 640px) {
    .preview-switcher {
      top: auto;
      bottom: 16px;
      right: 50%;
      transform: translateX(50%);
    }
    .pill {
      padding: 7px 11px;
      font-size: 11px;
    }
  }
</style>
