---
import { getLangFromUrl, languages, stripLangPrefix, type Lang } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const cleanPath = stripLangPrefix(Astro.url.pathname);

const links: Record<Lang, string> = {
  de: cleanPath,
  en: cleanPath === '/' ? '/en/' : `/en${cleanPath}`,
  tr: cleanPath === '/' ? '/tr/' : `/tr${cleanPath}`,
};

const codes = Object.keys(languages) as Lang[];

const groupLabelMap = {
  de: 'Sprache',
  en: 'Language',
  tr: 'Dil',
} as const;
const groupLabel = groupLabelMap[lang] ?? groupLabelMap.en;
---

<div class="lang-pill" role="group" aria-label={groupLabel}>
  {codes.map((code) => (
    <a
      href={links[code]}
      class:list={['lang-pill__link', lang === code ? 'is-active' : '']}
      data-lang={code}
      aria-current={lang === code ? 'page' : undefined}
    >
      {code.toUpperCase()}
    </a>
  ))}
</div>

<style>
  .lang-pill {
    display: inline-flex;
    align-items: center;
    background: var(--color-line);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 4px;
    gap: 2px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .lang-pill__link {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 5px 10px;
    border-radius: 999px;
    transition: color 200ms ease, background-color 200ms ease;
    line-height: 1;
  }

  .lang-pill__link:hover,
  .lang-pill__link:focus-visible {
    color: var(--color-text-primary);
    outline: none;
  }

  .lang-pill__link.is-active {
    background: var(--color-text-primary);
    color: var(--color-canvas);
  }

  .lang-pill__link.is-active:hover,
  .lang-pill__link.is-active:focus-visible {
    color: var(--color-canvas);
  }

  @media (max-width: 767px) {
    .lang-pill__link {
      font-size: 10px;
      padding: 4px 8px;
    }
  }
</style>

<script>
  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement | null;
    const link = target?.closest<HTMLAnchorElement>('a.lang-pill__link');
    if (!link) return;
    const lang = link.dataset.lang;
    if (!lang) return;
    try {
      localStorage.setItem('iamguer_lang', lang);
    } catch {
      // ignore storage errors
    }
  });
</script>
