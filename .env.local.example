# Instagram Graph API — siehe Apple Notes für die echten Werte
# Diese Datei dient als Template; eigene Datei: cp .env.local.example .env.local

IG_TOKEN=
IG_APP_SECRET=
IG_USER_ID=

# Optional: wenn gesetzt, triggert /api/sync-instagram nach erfolgreichem
# Fetch einen Vercel Deploy Hook, damit der statische Build die frischen
# Posts einbacken kann. Hook in Vercel > Project > Settings > Git > Deploy Hooks.
# VERCEL_DEPLOY_HOOK_URL=
