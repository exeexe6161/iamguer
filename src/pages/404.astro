---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" currentPath="/">
  <section class="px-7 py-16 max-w-4xl mx-auto">
    <h1 class="text-text-primary text-5xl tracking-tight font-light">Verlaufen?</h1>
    <p class="text-text-secondary mt-4">
      Diese Seite gibt's nicht. Geh zurück zur Startseite.
    </p>
    <a href="/" class="text-accent underline mt-4 inline-block">
      Zur Startseite
    </a>
  </section>
</BaseLayout>
