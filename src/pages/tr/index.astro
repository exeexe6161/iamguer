---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Splash from '../../components/Splash.astro';
import { loadInstagramPosts, displaySrc, shortCaption } from '../../lib/instagram';
import { getLangFromUrl, useTranslations, formatDate, localizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const payload = loadInstagramPosts();
const allPosts = payload?.posts ?? [];
const hero = allPosts[0];
const gridPosts = allPosts.slice(1, 13);

const altFallback = t('home.altFallback');
const heroSrc = hero ? displaySrc(hero) : '/splash/portrait-pool.jpg';
const heroAlt = hero
  ? shortCaption(hero.caption, 120) || altFallback
  : altFallback;
const heroCaption = hero ? shortCaption(hero.caption, 80) : '';
const heroDate = hero ? formatDate(hero.timestamp, lang) : '';
const heroPermalink = hero?.permalink;
---

<BaseLayout
  title="iamguer"
  description={t('home.metaDescription')}
  currentPath="/"
>
  <Fragment slot="head-extra">
    <script is:inline>
      (function () {
        try {
          var url = new URL(window.location.href);
          var skip = url.searchParams.get('skip') === '1';
          var seen = sessionStorage.getItem('iamguer_splash_seen') === '1';
          if (skip || seen) {
            document.documentElement.classList.add('splash-skip');
          } else {
            document.documentElement.classList.add('splash-show');
          }
        } catch (e) {
          document.documentElement.classList.add('splash-show');
        }
      })();
    </script>
    <link
      rel="preload"
      href="/splash/portrait-pool.avif"
      as="image"
      type="image/avif"
      fetchpriority="high"
    />
    {
      allPosts.length > 0 && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'ImageGallery',
            name: t('home.schemaName'),
            description: t('home.schemaDescription'),
            url: 'https://iamguer.com/',
            author: {
              '@type': 'Person',
              name: 'Hakan',
              url: 'https://iamguer.com',
            },
            image: allPosts.slice(0, 9).map((p) => ({
              '@type': 'ImageObject',
              contentUrl: p.media_url,
              url: p.permalink,
              ...(p.caption ? { caption: shortCaption(p.caption, 200) } : {}),
              uploadDate: p.timestamp,
              creator: {
                '@type': 'Person',
                name: 'Hakan',
              },
            })),
          })}
        />
      )
    }
  </Fragment>

  <Splash />

  <section class="page-hero">
    <div class="page-hero__photo">
      <img
        src={heroSrc}
        alt={heroAlt}
        title={heroDate || undefined}
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </div>

    {hero && (
      <article class="hero-info-card">
        <div class="hero-info-card__row">
          <div class="hero-info-card__meta">
            <img
              src={heroSrc}
              alt=""
              class="hero-info-card__thumb"
              loading="eager"
              decoding="async"
            />
            <div class="hero-info-card__title">
              <span class="hero-info-card__caption">
                {heroCaption || altFallback}
              </span>
              <small class="hero-info-card__date">{heroDate}</small>
            </div>
          </div>
          {heroPermalink && (
            <a
              href={heroPermalink}
              target="_blank"
              rel="noopener noreferrer"
              class="hero-info-card__cta"
            >
              {t('home.onInstagramShort')}<span aria-hidden="true"> ↗</span>
            </a>
          )}
        </div>
        <div class="hero-info-card__divider"></div>
        <div class="hero-info-card__tabs">
          <span class="hero-info-card__label">{t('home.latestPost')}</span>
          <nav
            class="hero-info-card__tab-nav"
            aria-label={t('home.latestPost')}
          >
            <a
              href={localizedPath('/', lang)}
              class="is-active"
              aria-current="page"
            >
              {t('nav.index')}
            </a>
            <a href={localizedPath('/galerien', lang)}>
              {t('nav.galerien')}
            </a>
          </nav>
        </div>
      </article>
    )}
  </section>

  {
    gridPosts.length > 0 && (
      <section class="home-grid reveal">
        <ul>
          {gridPosts.map((post, i) => (
            <li
              class="grid-item bento-stagger"
              style={`--stagger-delay: ${i * 60}ms`}
            >
              <a
                href={post.permalink}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={shortCaption(post.caption, 80) || altFallback}
              >
                <img
                  src={displaySrc(post)}
                  alt={shortCaption(post.caption, 120) || altFallback}
                  title={formatDate(post.timestamp, lang)}
                  loading="lazy"
                  decoding="async"
                />
                {post.media_type === 'VIDEO' && (
                  <span class="grid-item__badge">Video</span>
                )}
                {post.media_type === 'CAROUSEL_ALBUM' && (
                  <span class="grid-item__badge">Album</span>
                )}
                <span class="grid-item__date">
                  {formatDate(post.timestamp, lang)}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    allPosts.length === 0 && (
      <section class="home-grid-empty reveal">
        <p>{t('home.noImagesYet')}</p>
      </section>
    )
  }
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    height: 100vh;
    min-height: 580px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: 0 16px 18px;
    background: var(--color-canvas);
  }

  .page-hero__photo {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .page-hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.92);
    transform: scale(1.04);
    animation: page-hero-kenburns 18s ease-out forwards;
    will-change: transform;
  }

  @keyframes page-hero-kenburns {
    to {
      transform: scale(1);
    }
  }

  .page-hero__photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.18) 0%,
      transparent 25%,
      transparent 70%,
      rgba(0, 0, 0, 0.45) 100%
    );
    pointer-events: none;
  }

  .hero-info-card {
    position: relative;
    z-index: 1;
    margin-left: auto;
    width: 100%;
    background: var(--color-text-primary);
    color: var(--color-canvas);
    border-radius: 14px;
    padding: 12px 14px;
    box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.45);
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: 'Inter Variable', system-ui, sans-serif;
    animation: hero-info-card-in 600ms cubic-bezier(0.2, 0.8, 0.2, 1) 200ms both;
  }

  @keyframes hero-info-card-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-info-card__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .hero-info-card__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    flex: 1;
  }

  .hero-info-card__thumb {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .hero-info-card__title {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.2;
    min-width: 0;
    color: inherit;
  }

  .hero-info-card__caption {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    word-break: break-word;
  }

  .hero-info-card__date {
    display: block;
    opacity: 0.5;
    font-weight: 400;
    font-size: 11px;
    margin-top: 2px;
    letter-spacing: 0.02em;
  }

  .hero-info-card__cta {
    background: var(--color-canvas);
    color: var(--color-text-primary);
    border: none;
    border-radius: 999px;
    padding: 8px 14px;
    font-family: inherit;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 200ms ease, transform 200ms ease;
    flex-shrink: 0;
    line-height: 1;
  }

  .hero-info-card__cta:hover,
  .hero-info-card__cta:focus-visible {
    opacity: 0.85;
    outline: none;
  }

  .hero-info-card__divider {
    height: 1px;
    background: rgba(0, 0, 0, 0.08);
  }

  :global([data-theme='light']) .hero-info-card__divider {
    background: rgba(255, 255, 255, 0.12);
  }

  .hero-info-card__tabs {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    gap: 12px;
  }

  .hero-info-card__label {
    font-weight: 500;
  }

  .hero-info-card__tab-nav {
    display: flex;
    gap: 16px;
  }

  .hero-info-card__tab-nav a {
    color: inherit;
    text-decoration: none;
    opacity: 0.45;
    transition: opacity 200ms ease;
  }

  .hero-info-card__tab-nav a.is-active {
    opacity: 1;
    font-weight: 500;
  }

  .hero-info-card__tab-nav a:hover,
  .hero-info-card__tab-nav a:focus-visible {
    opacity: 0.8;
    outline: none;
  }

  .hero-info-card__tab-nav a.is-active:hover,
  .hero-info-card__tab-nav a.is-active:focus-visible {
    opacity: 1;
  }

  @media (min-width: 800px) {
    .page-hero {
      padding: 0 28px 28px;
    }
    .hero-info-card {
      width: 360px;
      padding: 14px 16px;
    }
    .hero-info-card__title {
      font-size: 14px;
    }
  }

  /* Grid */
  .home-grid {
    background: var(--color-canvas);
    max-width: 1400px;
    margin: 0 auto;
    padding: 30px 16px 50px;
  }

  .home-grid ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
  }

  .grid-item {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 4px;
    background: var(--color-tile);
  }

  .grid-item a {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .grid-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .grid-item a:hover img,
  .grid-item a:focus-visible img {
    transform: scale(1.04);
  }

  .grid-item__date {
    position: absolute;
    inset: auto 0 0 0;
    padding: 14px 10px 8px;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.7),
      transparent
    );
    color: #fff;
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.02em;
    opacity: 1;
    transition: opacity 300ms ease;
    pointer-events: none;
  }

  .grid-item__badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-family: ui-monospace, 'SF Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    background: rgba(10, 10, 10, 0.7);
    padding: 4px 8px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .home-grid-empty {
    background: var(--color-canvas);
    padding: 64px 24px;
    text-align: center;
  }

  .home-grid-empty p {
    font-family: ui-monospace, 'SF Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (min-width: 800px) {
    .home-grid {
      padding: 60px 28px 80px;
    }
    .home-grid ul {
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    .grid-item__date {
      opacity: 0;
      padding: 18px 12px 10px;
      font-size: 11px;
    }
    .grid-item:hover .grid-item__date,
    .grid-item:focus-within .grid-item__date {
      opacity: 1;
    }
  }

  @media (min-width: 1024px) {
    .home-grid-empty {
      padding: 160px 48px;
    }
  }

  /* Reveal */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 800ms cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 800ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .bento-stagger {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 700ms cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 700ms cubic-bezier(0.25, 0.1, 0.25, 1);
    transition-delay: var(--stagger-delay, 0ms);
  }

  .bento-stagger.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .page-hero__photo img {
      animation: none;
      transform: none;
    }
    .hero-info-card {
      animation: none;
    }
    .grid-item img,
    .grid-item__date {
      transition: none;
    }
    .grid-item a:hover img,
    .grid-item a:focus-visible img {
      transform: none;
    }
    .reveal,
    .bento-stagger {
      transition: opacity 400ms ease;
      transform: none;
    }
    .reveal:not(.is-visible),
    .bento-stagger:not(.is-visible) {
      transform: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var revealNodes = document.querySelectorAll('.reveal');
    var staggerNodes = document.querySelectorAll('.bento-stagger');

    if (!('IntersectionObserver' in window)) {
      revealNodes.forEach(function (n) { n.classList.add('is-visible'); });
      staggerNodes.forEach(function (n) { n.classList.add('is-visible'); });
      return;
    }

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    revealNodes.forEach(function (n) { io.observe(n); });

    var staggerIo = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          staggerIo.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    staggerNodes.forEach(function (n) { staggerIo.observe(n); });
  })();
</script>
