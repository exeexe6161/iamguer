---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { getLangFromUrl, useTranslations, localizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const logsItems = t<string[]>('datenschutz.logsItems');
const rechteItems = t<string[]>('datenschutz.rechteItems');

const standDatum = '04.05.2026';
---

<BaseLayout
  title={t('datenschutz.metaTitle')}
  description={t('datenschutz.metaDescription')}
  currentPath="/datenschutz"
>
  <article class="px-7 py-16 md:py-24 max-w-3xl mx-auto">
    <header class="flex items-center gap-4">
      <Icon name="shield" class="text-text-secondary" size={28} />
      <h1 class="text-text-primary text-5xl tracking-tight font-light">
        {t('datenschutz.heading')}
      </h1>
    </header>

    <section class="mt-16">
      <h2 class="text-text-primary text-xl font-normal">{t('datenschutz.verantwortlicherHeading')}</h2>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.verantwortlicherP1Before')}<a
          href={localizedPath('/impressum', lang)}
          class="text-accent hover:text-text-primary transition-colors"
          >{t('datenschutz.verantwortlicherP1LinkLabel')}</a
        >{t('datenschutz.verantwortlicherP1After')}
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-text-primary text-xl font-normal">{t('datenschutz.hostingHeading')}</h2>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.hostingP1')}
      </p>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.hostingP2Label')}
        <a
          href="https://vercel.com/legal/privacy-policy"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:text-text-primary transition-colors inline-flex items-baseline gap-1 ml-1"
        >
          vercel.com/legal/privacy-policy
          <Icon name="external-link" class="text-text-secondary" size={12} />
        </a>
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-text-primary text-xl font-normal">{t('datenschutz.cookiesHeading')}</h2>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.cookiesP1')}
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-text-primary text-xl font-normal">{t('datenschutz.instagramHeading')}</h2>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.instagramP1')}
      </p>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.instagramP2Label')}
        <a
          href="https://www.facebook.com/about/privacy"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:text-text-primary transition-colors inline-flex items-baseline gap-1 ml-1"
        >
          facebook.com/about/privacy
          <Icon name="external-link" class="text-text-secondary" size={12} />
        </a>
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-text-primary text-xl font-normal">{t('datenschutz.domainHeading')}</h2>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.domainP1')}
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-text-primary text-xl font-normal">{t('datenschutz.logsHeading')}</h2>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.logsP1')}
      </p>
      <ul
        class="mt-4 space-y-2 list-disc list-inside text-text-body leading-relaxed font-light marker:text-text-muted"
      >
        {logsItems.map((item) => <li>{item}</li>)}
      </ul>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.logsP2')}
      </p>
    </section>

    <section class="mt-12">
      <h2
        class="text-text-primary text-xl font-normal flex items-center gap-3"
      >
        <Icon name="mail" class="text-text-secondary" />
        {t('datenschutz.kontaktHeading')}
      </h2>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.kontaktP1Before')}<a
          href="mailto:hello@iamguer.com"
          class="text-accent hover:text-text-primary transition-colors"
          >hello@iamguer.com</a
        >{t('datenschutz.kontaktP1After')}
      </p>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.kontaktP2')}
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-text-primary text-xl font-normal">{t('datenschutz.rechteHeading')}</h2>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.rechteP1')}
      </p>
      <ul
        class="mt-4 space-y-2 list-disc list-inside text-text-body leading-relaxed font-light marker:text-text-muted"
      >
        {rechteItems.map((item) => <li>{item}</li>)}
      </ul>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.rechteP2Before')}<a
          href="mailto:hello@iamguer.com"
          class="text-accent hover:text-text-primary transition-colors"
          >hello@iamguer.com</a
        >{t('datenschutz.rechteP2After')}
      </p>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.rechteP3')}
        <a
          href="https://datenschutz.hessen.de"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:text-text-primary transition-colors inline-flex items-baseline gap-1 ml-1"
        >
          datenschutz.hessen.de
          <Icon name="external-link" class="text-text-secondary" size={12} />
        </a>
      </p>
    </section>

    <section class="mt-12">
      <h2 class="text-text-primary text-xl font-normal">{t('datenschutz.aktualitaetHeading')}</h2>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.aktualitaetStand', { date: standDatum })}
      </p>
      <p class="mt-4 text-text-body leading-relaxed font-light">
        {t('datenschutz.aktualitaetP2')}
      </p>
    </section>
  </article>
</BaseLayout>
