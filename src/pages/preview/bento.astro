---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Splash from '../../components/Splash.astro';
import PreviewSwitcher from '../../components/PreviewSwitcher.astro';
import { loadInstagramPosts, displaySrc, shortCaption } from '../../lib/instagram';

const payload = loadInstagramPosts();
const allPosts = payload?.posts ?? [];
const tiles = allPosts.slice(0, 10);

const dateFmt = new Intl.DateTimeFormat('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Asymmetric tile pattern
// row 1-2: tile-0 (7×2), tile-1 (5×1 top-right), tile-2 (5×1 below tile-1)
// row 3:   tile-3, tile-4, tile-5 (4 each)
// row 4:   tile-6 (6), tile-7 (3), tile-8 (3)
// row 5:   tile-9 (12, low-aspect)
const slotClasses = [
  'tile slot-0',
  'tile slot-1',
  'tile slot-2',
  'tile slot-3',
  'tile slot-4',
  'tile slot-5',
];
const slotClassesB = [
  'tile slot-6',
  'tile slot-7',
  'tile slot-8',
  'tile slot-9',
];

const blockA = tiles.slice(0, 6);
const blockB = tiles.slice(6, 10);
---

<BaseLayout
  title="Preview — Bento"
  description="Vorschau Konzept 3: Bento Mosaic"
  currentPath="/preview/bento"
  noIndex={true}
>
  <Fragment slot="head-extra">
    <script is:inline>
      (function () {
        try {
          var url = new URL(window.location.href);
          var skip = url.searchParams.get('skip') === '1';
          var seen = sessionStorage.getItem('iamguer_splash_seen') === '1';
          if (skip || seen) {
            document.documentElement.classList.add('splash-skip');
          } else {
            document.documentElement.classList.add('splash-show');
          }
        } catch (e) {
          document.documentElement.classList.add('splash-show');
        }
      })();
    </script>
    <link
      rel="preload"
      href="/splash/portrait-pool.avif"
      as="image"
      type="image/avif"
      fetchpriority="high"
    />
  </Fragment>

  <Splash />
  <PreviewSwitcher current="bento" />

  {
    tiles.length === 0 ? (
      <section class="bento-empty">
        <p>Bento-Grid zeigt sich, sobald Instagram-Posts geladen sind.</p>
      </section>
    ) : (
      <>
        <section class="bento-grid bento-grid-a" aria-label="Foto-Mosaik, Block 1">
          {blockA.map((post, i) => (
            <a
              class:list={[slotClasses[i], 'bento-stagger']}
              data-stagger={i}
              href={post.permalink}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={shortCaption(post.caption, 80) || 'Fotografie von Hakan / iamguer'}
            >
              <img
                src={displaySrc(post)}
                alt={shortCaption(post.caption, 120) || 'Fotografie von Hakan / iamguer'}
                loading={i < 3 ? 'eager' : 'lazy'}
                decoding="async"
                fetchpriority={i === 0 ? 'high' : 'auto'}
              />
              {(post.caption || post.timestamp) && (
                <span class="tile-overlay">
                  {post.caption && <span class="tile-cap">{shortCaption(post.caption, 100)}</span>}
                  <span class="tile-date">{dateFmt.format(new Date(post.timestamp))}</span>
                </span>
              )}
            </a>
          ))}
        </section>

        <section class="bento-statement reveal">
          <h2>Marburg und der Rest</h2>
        </section>

        {blockB.length > 0 && (
          <section class="bento-grid bento-grid-b" aria-label="Foto-Mosaik, Block 2">
            {blockB.map((post, i) => (
              <a
                class:list={[slotClassesB[i], 'bento-stagger']}
                data-stagger={i}
                href={post.permalink}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={shortCaption(post.caption, 80) || 'Fotografie von Hakan / iamguer'}
              >
                <img
                  src={displaySrc(post)}
                  alt={shortCaption(post.caption, 120) || 'Fotografie von Hakan / iamguer'}
                  loading="lazy"
                  decoding="async"
                />
                {(post.caption || post.timestamp) && (
                  <span class="tile-overlay">
                    {post.caption && <span class="tile-cap">{shortCaption(post.caption, 100)}</span>}
                    <span class="tile-date">{dateFmt.format(new Date(post.timestamp))}</span>
                  </span>
                )}
              </a>
            ))}
          </section>
        )}
      </>
    )
  }

  <section class="bento-cta reveal">
    <a href="/galerien" class="bento-cta-link">
      Alle Bilder ansehen
      <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>

<style>
  .bento-empty {
    padding: 160px 24px;
    text-align: center;
    color: var(--color-text-muted);
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 300;
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 22vw;
    gap: 16px;
    padding: 80px 24px 0;
  }

  .bento-grid-b {
    padding: 0 24px;
    grid-auto-rows: 26vw;
  }

  @media (min-width: 768px) {
    .bento-grid,
    .bento-grid-b {
      gap: 24px;
      padding-left: 48px;
      padding-right: 48px;
    }
  }

  /* Tile base */
  .tile {
    position: relative;
    overflow: hidden;
    background: var(--color-tile);
    text-decoration: none;
    display: block;
  }

  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease, filter 400ms ease;
  }

  .tile:hover img,
  .tile:focus-visible img {
    transform: scale(1.02);
    filter: brightness(1.15);
  }

  .tile-overlay {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 16px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: var(--color-text-primary);
    transform: translateY(100%);
    transition: transform 360ms ease;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tile:hover .tile-overlay,
  .tile:focus-visible .tile-overlay {
    transform: translateY(0);
  }

  .tile-cap {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 300;
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-text-primary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tile-date {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 400;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Block A spans */
  .slot-0 { grid-column: span 7; grid-row: span 2; }
  .slot-1 { grid-column: span 5; grid-row: span 1; }
  .slot-2 { grid-column: span 5; grid-row: span 1; }
  .slot-3 { grid-column: span 4; grid-row: span 1; }
  .slot-4 { grid-column: span 4; grid-row: span 1; }
  .slot-5 { grid-column: span 4; grid-row: span 1; }

  /* Block B spans */
  .slot-6 { grid-column: span 6; grid-row: span 1; }
  .slot-7 { grid-column: span 3; grid-row: span 1; }
  .slot-8 { grid-column: span 3; grid-row: span 1; }
  .slot-9 { grid-column: span 12; grid-row: span 1; }

  /* Statement between blocks */
  .bento-statement {
    padding: 120px 24px;
    text-align: center;
  }

  .bento-statement h2 {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 200;
    font-size: clamp(36px, 7vw, 120px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin: 0 auto;
    max-width: 14ch;
  }

  /* CTA */
  .bento-cta {
    padding: 120px 24px;
    text-align: center;
  }

  .bento-cta-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 200;
    font-size: clamp(28px, 5vw, 72px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .bento-cta-link:hover,
  .bento-cta-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 8px;
    text-decoration-thickness: 1px;
    outline: none;
  }

  /* Stagger reveal */
  .bento-stagger {
    opacity: 0;
    transform: translateY(24px) scale(0.985);
    transition:
      opacity 700ms cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 700ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .bento-stagger.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 800ms cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 800ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Tablet */
  @media (max-width: 1024px) and (min-width: 768px) {
    .bento-grid,
    .bento-grid-b {
      grid-auto-rows: 38vw;
    }

    .slot-0 { grid-column: span 12; grid-row: span 1; }
    .slot-1 { grid-column: span 12; grid-row: span 1; }
    .slot-2 { grid-column: span 12; grid-row: span 1; }
    .slot-3 { grid-column: span 6; }
    .slot-4 { grid-column: span 6; }
    .slot-5 { grid-column: span 12; }
    .slot-6 { grid-column: span 12; }
    .slot-7 { grid-column: span 6; }
    .slot-8 { grid-column: span 6; }
    .slot-9 { grid-column: span 12; }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .bento-grid,
    .bento-grid-b {
      gap: 8px;
      padding-left: 16px;
      padding-right: 16px;
      padding-top: 56px;
      grid-auto-rows: 80vw;
    }

    .bento-grid-b { padding-top: 0; }

    .tile {
      grid-column: span 12 !important;
      grid-row: span 1 !important;
    }

    /* On mobile, show overlay subtly all the time on tap-targets */
    .tile-overlay {
      transform: translateY(0);
      background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.55) 100%);
      padding: 20px 16px 16px;
    }

    .bento-statement { padding: 80px 20px; }
    .bento-cta { padding: 80px 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tile img,
    .tile-overlay {
      transition: none;
    }
    .tile:hover img,
    .tile:focus-visible img {
      transform: none;
      filter: none;
    }
    .bento-stagger,
    .reveal {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var staggerNodes = document.querySelectorAll('.bento-stagger');
    var revealNodes = document.querySelectorAll('.reveal');

    function revealStagger(el) {
      var idx = parseInt(el.getAttribute('data-stagger') || '0', 10);
      var delay = reduceMotion ? 0 : idx * 80;
      window.setTimeout(function () {
        el.classList.add('is-visible');
      }, delay);
    }

    if ('IntersectionObserver' in window) {
      var staggerIo = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            revealStagger(entry.target);
            staggerIo.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      staggerNodes.forEach(function (n) { staggerIo.observe(n); });

      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      revealNodes.forEach(function (n) { io.observe(n); });
    } else {
      staggerNodes.forEach(function (n) { n.classList.add('is-visible'); });
      revealNodes.forEach(function (n) { n.classList.add('is-visible'); });
    }
  })();
</script>
