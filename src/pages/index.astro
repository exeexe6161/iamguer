---
import BaseLayout from '../layouts/BaseLayout.astro';
import Splash from '../components/Splash.astro';
---

<BaseLayout currentPath="/">
  <Fragment slot="head-extra">
    <script is:inline>
      (function () {
        try {
          var url = new URL(window.location.href);
          var skip = url.searchParams.get('skip') === '1';
          var seen = sessionStorage.getItem('iamguer_splash_seen') === '1';
          if (skip || seen) {
            document.documentElement.classList.add('splash-skip');
          } else {
            document.documentElement.classList.add('splash-show');
          }
        } catch (e) {
          document.documentElement.classList.add('splash-show');
        }
      })();
    </script>
    <link
      rel="preload"
      href="/splash/portrait-pool.avif"
      as="image"
      type="image/avif"
      fetchpriority="high"
    />
  </Fragment>

  <Splash />

  <section class="px-7 py-24">
    <h1
      class="text-text-primary text-7xl md:text-9xl tracking-tighter leading-none font-light"
    >
      iamguer
    </h1>
    <p
      class="text-text-secondary text-lg mt-6 max-w-md leading-relaxed"
    >
      Bilder aus Marburg und überall sonst — in voller Auflösung, mit Raum zum
      Atmen.
    </p>
  </section>
</BaseLayout>
