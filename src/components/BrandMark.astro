---
interface Props {
  label?: string;
  size?: number;
  wordmark?: boolean;
}

const { label = 'iamguer', size = 40, wordmark = false } = Astro.props;
const lightSrc = wordmark ? '/brand/iamguer-wordmark-light.svg' : '/brand/iamguer-icon-light.svg';
const darkSrc = wordmark ? '/brand/iamguer-wordmark-dark.svg' : '/brand/iamguer-icon-dark.svg';
---

<span class:list={['brand-mark', wordmark ? 'brand-mark--wordmark' : 'brand-mark--icon']} style={'--brand-mark-size: ' + size + 'px'} aria-label={label} role="img">
  <img class="brand-mark__asset brand-mark__asset--light" src={lightSrc} alt="" aria-hidden="true" loading="eager" decoding="async" />
  <img class="brand-mark__asset brand-mark__asset--dark" src={darkSrc} alt="" aria-hidden="true" loading="eager" decoding="async" />
</span>

<style>
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--brand-mark-size, 40px);
    flex: 0 0 auto;
  }

  .brand-mark--icon {
    width: var(--brand-mark-size, 40px);
  }

  .brand-mark--wordmark {
    width: calc(var(--brand-mark-size, 40px) * 3.6);
  }

  .brand-mark__asset {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .brand-mark__asset--dark {
    display: none;
  }

  :global([data-theme='light']) .brand-mark__asset--dark {
    display: block;
  }

  :global([data-theme='light']) .brand-mark__asset--light {
    display: none;
  }
</style>
