---
import { loadInstagramPosts, displaySrc, shortCaption } from '../lib/instagram';
import { getLangFromUrl, useTranslations, formatDate } from '../i18n/utils';

const payload = loadInstagramPosts();
const posts = payload?.posts ?? [];
const fetchedAt = payload?.fetchedAt;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const altFallback = t('home.altFallback');
---

{
  posts.length === 0 ? (
    <p class="text-text-muted font-mono text-xs uppercase tracking-widest">
      {t('instagramGallery.empty')}
    </p>
  ) : (
    <div class="space-y-6">
      <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
        {posts.map((post) => (
          <li class="group relative aspect-square overflow-hidden bg-tile">
            <a
              href={post.permalink}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={shortCaption(post.caption, 80) || altFallback}
              class="block w-full h-full"
            >
              <img
                src={displaySrc(post)}
                alt={shortCaption(post.caption, 120) || altFallback}
                title={formatDate(post.timestamp, lang)}
                loading="lazy"
                decoding="async"
                draggable="false"
                class="photo-protected w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              {post.media_type === 'VIDEO' && (
                <span class="absolute top-2 right-2 font-mono text-[10px] uppercase tracking-widest text-text-primary bg-canvas/70 px-2 py-1 backdrop-blur-sm">
                  Video
                </span>
              )}
              {post.media_type === 'CAROUSEL_ALBUM' && (
                <span class="absolute top-2 right-2 font-mono text-[10px] uppercase tracking-widest text-text-primary bg-canvas/70 px-2 py-1 backdrop-blur-sm">
                  Album
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>

      {fetchedAt && (
        <p class="font-mono text-[10px] uppercase tracking-widest text-text-trace">
          {t('instagramGallery.lastSync')} {formatDate(fetchedAt, lang)}
        </p>
      )}
    </div>
  )
}
