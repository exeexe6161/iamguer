---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Über" currentPath="/ueber">
  <section class="px-7 py-16 max-w-4xl mx-auto">
    <h1 class="font-serif text-text-primary text-5xl">Hallo. Ich bin Guer.</h1>
    <p class="text-text-secondary mt-4">
      Bilder aus Marburg und überall sonst — Licht, Schatten, leise Momente.
    </p>
  </section>
</BaseLayout>
