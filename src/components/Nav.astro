---
import BrandMark from './BrandMark.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeSwitcher from './ThemeSwitcher.astro';
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

interface Props {
  currentPath?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<nav class="site-nav" aria-label="Top">
  <a
    href={localizedPath('/', lang)}
    class="site-nav__logo"
    aria-label="iamguer"
  >
    <BrandMark />
  </a>

  <button
    type="button"
    class="site-nav__menu-trigger"
    aria-label={t('nav.menuOpen')}
    aria-controls="siteMenuOverlay"
    aria-expanded="false"
    data-menu-open
  >
    <span></span><span></span><span></span>
    <span></span><span></span><span></span>
    <span></span><span></span><span></span>
  </button>

  <div class="site-nav__cluster">
    <LanguageSwitcher />
    <ThemeSwitcher />
  </div>
</nav>

<style>
  .site-nav {
    position: relative;
    z-index: 40;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 14px 16px;
    background: var(--color-canvas);
    border-bottom: 1px solid var(--color-line);
  }

  :global(body.is-home) .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: transparent;
    border-bottom: none;
    pointer-events: none;
  }

  :global(body.is-home) .site-nav > * {
    pointer-events: auto;
  }

  @media (min-width: 768px) {
    .site-nav {
      padding: 22px 28px;
    }
  }

  .site-nav__logo {
    color: var(--color-text-primary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-self: start;
  }

  .site-nav__menu-trigger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 12px;
    display: grid;
    grid-template-columns: repeat(3, 4px);
    grid-template-rows: repeat(3, 4px);
    gap: 5px;
    justify-self: center;
    transition: opacity 0.3s ease, transform 0.3s ease;
    color: var(--color-text-primary);
  }

  .site-nav__menu-trigger:hover,
  .site-nav__menu-trigger:focus-visible {
    opacity: 0.65;
    transform: scale(0.94);
    outline: none;
  }

  .site-nav__menu-trigger span {
    background: currentColor;
    border-radius: 50%;
    width: 4px;
    height: 4px;
    transition: background 300ms ease;
  }

  .site-nav__cluster {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    align-items: center;
    justify-self: end;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav__menu-trigger {
      transition: none;
    }
    .site-nav__menu-trigger:hover,
    .site-nav__menu-trigger:focus-visible {
      transform: none;
    }
  }
</style>
