---
import '../styles/tokens.css';
import Nav from '../components/Nav.astro';
import MenuOverlay from '../components/MenuOverlay.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations, stripLangPrefix } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  noIndex?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const {
  title = 'iamguer',
  description = t('home.metaDescription'),
  currentPath = '/',
  ogImage = '/og-image.png',
  ogType = 'website',
  noIndex = false,
} = Astro.props;

const siteUrl = Astro.site ?? Astro.url;
const computedTitle = title === 'iamguer' ? 'iamguer' : `${title} · iamguer`;
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

const ogLocaleMap = { de: 'de_DE', en: 'en_GB', tr: 'tr_TR' } as const;

const cleanPath = stripLangPrefix(Astro.url.pathname);
const altDe = `https://iamguer.com${cleanPath}`;
const altEn = cleanPath === '/' ? 'https://iamguer.com/en/' : `https://iamguer.com/en${cleanPath}`;
const altTr = cleanPath === '/' ? 'https://iamguer.com/tr/' : `https://iamguer.com/tr${cleanPath}`;

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Hakan',
  alternateName: 'iamguer',
  url: 'https://iamguer.com',
  jobTitle: 'Fotograf',
  knowsAbout: [
    'Fotografie',
    'Porträtfotografie',
    'Reisefotografie',
    'Marburg',
  ],
  sameAs: ['https://www.instagram.com/iamguer'],
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('iamguer_theme');
          if (stored === 'light' || stored === 'dark') {
            document.documentElement.dataset.theme = stored;
            return;
          }
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = prefersDark ? 'dark' : 'light';
          document.documentElement.dataset.theme = theme;
          localStorage.setItem('iamguer_theme', theme);
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
    <script is:inline>
      (function () {
        try {
          var validLangs = ['de', 'en', 'tr'];
          var path = window.location.pathname;
          var pathLang = 'de';
          if (path === '/en' || path.indexOf('/en/') === 0) pathLang = 'en';
          else if (path === '/tr' || path.indexOf('/tr/') === 0) pathLang = 'tr';

          var stored = null;
          try { stored = localStorage.getItem('iamguer_lang'); } catch (e) {}

          if (stored && validLangs.indexOf(stored) !== -1) {
            if (stored !== pathLang) {
              var dePath = path.replace(/^\/(en|tr)(?=\/|$)/, '') || '/';
              var newPath = stored === 'de'
                ? dePath
                : '/' + stored + (dePath === '/' ? '/' : dePath);
              if (newPath !== path) {
                window.location.replace(newPath);
                return;
              }
            }
            return;
          }

          var langChoice;
          if (pathLang !== 'de') {
            langChoice = pathLang;
          } else {
            var bl = (navigator.language || 'de').split('-')[0].toLowerCase();
            langChoice = bl === 'en' ? 'en' : bl === 'tr' ? 'tr' : 'de';
          }
          try { localStorage.setItem('iamguer_lang', langChoice); } catch (e) {}

          if (langChoice !== 'de' && pathLang === 'de') {
            var redirectPath = '/' + langChoice + (path === '/' ? '/' : path);
            window.location.replace(redirectPath);
          }
        } catch (e) {
          // never block page render on detection errors
        }
      })();
    </script>
    <title>{computedTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="de" href={altDe} />
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="tr" href={altTr} />
    <link rel="alternate" hreflang="x-default" href={altDe} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="application-name" content="iamguer" />

    <meta name="msapplication-TileColor" content="#0a0a0a" />
    <meta name="msapplication-config" content="/browserconfig.xml" />

    <meta name="apple-mobile-web-app-title" content="iamguer" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <link
      rel="preload"
      href="/fonts/inter/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:site_name" content="iamguer" />
    <meta property="og:locale" content={ogLocaleMap[lang]} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(personJsonLd)}
    />

    <meta name="generator" content={Astro.generator} />
    <slot name="head-extra" />
  </head>
  <body
    class:list={[
      'bg-canvas text-text-body font-sans antialiased min-h-screen flex flex-col',
      cleanPath === '/' && 'is-home',
    ]}
  >
    <Nav currentPath={currentPath} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <MenuOverlay />
    <script is:inline>
      (function () {
        document.addEventListener('contextmenu', function (e) {
          var target = e.target;
          if (target instanceof Element && target.closest('.photo-protected')) {
            e.preventDefault();
          }
        });
      })();
    </script>
  </body>
</html>
