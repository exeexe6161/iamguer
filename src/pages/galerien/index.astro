---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InstagramGallery from '../../components/InstagramGallery.astro';
import { getCollection } from 'astro:content';
import { loadInstagramPosts, shortCaption } from '../../lib/instagram';

const entries = (await getCollection('galerien')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const igPayload = loadInstagramPosts();
const igPosts = igPayload?.posts ?? [];

const dateFmt = new Intl.DateTimeFormat('de-DE', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout
  title="Galerien"
  description="Vollständige Foto-Galerie von iamguer. Aufnahmen aus Marburg und unterwegs, kuratiert von Hakan."
  currentPath="/galerien"
>
  {
    igPosts.length > 0 && (
      <Fragment slot="head-extra">
        <script
          type="application/ld+json"
          set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'ImageGallery',
            name: 'iamguer — Galerien',
            description:
              'Vollständige Sammlung der Fotografien von Hakan auf iamguer.com.',
            url: 'https://iamguer.com/galerien',
            author: {
              '@type': 'Person',
              name: 'Hakan',
              url: 'https://iamguer.com',
            },
            image: igPosts.slice(0, 50).map((p) => ({
              '@type': 'ImageObject',
              contentUrl: p.media_url,
              url: p.permalink,
              ...(p.caption ? { caption: shortCaption(p.caption, 200) } : {}),
              uploadDate: p.timestamp,
              creator: {
                '@type': 'Person',
                name: 'Hakan',
              },
            })),
          })}
        />
      </Fragment>
    )
  }
  <section class="px-7 py-16 max-w-4xl mx-auto">
    <h1 class="text-text-primary text-5xl tracking-tight font-light">Galerien</h1>
    <p class="text-text-secondary mt-4">
      Visuelle Notizen aus Marburg und unterwegs.
    </p>

    <div class="mt-16">
      <header class="flex items-baseline justify-between mb-6">
        <h2 class="text-text-primary text-2xl tracking-tight font-light">
          Aus Instagram
        </h2>
        <a
          href="https://instagram.com/iamguer"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs uppercase tracking-widest text-text-muted hover:text-text-primary transition-colors"
        >
          @iamguer ↗
        </a>
      </header>
      <InstagramGallery />
    </div>

    {
      entries.length > 0 && (
        <div class="mt-20">
          <h2 class="text-text-primary text-2xl tracking-tight font-light mb-6">
            Notizen
          </h2>
          <ul class="space-y-10">
            {entries.map((entry) => (
              <li>
                <a href={`/galerien/${entry.id}`} class="block group">
                  <h3 class="text-text-primary text-xl group-hover:text-accent transition-colors">
                    {entry.data.title}
                  </h3>
                  <p class="text-text-secondary mt-2">{entry.data.excerpt}</p>
                  <p class="font-mono text-xs uppercase tracking-widest text-text-muted mt-2">
                    {dateFmt.format(entry.data.date)}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>
</BaseLayout>
