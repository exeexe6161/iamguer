---
const year = new Date().getFullYear();

const sitemapLinks = [
  { href: '/galerien', label: 'Galerien' },
  { href: '/notizen', label: 'Notizen' },
  { href: '/kontakt', label: 'Kontakt' },
];

const followLinks = [
  { href: 'https://instagram.com/iamguer', label: 'Instagram ↗', external: true },
  { href: '#', label: 'Newsletter', external: false },
];

const legalLinks = [
  { href: '/impressum', label: 'Impressum' },
  { href: '/datenschutz', label: 'Datenschutz' },
];
---

<footer class="border-t border-line px-7 pt-8 pb-4 mt-16">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <h4 class="font-mono text-xs uppercase tracking-widest text-text-muted mb-3">Sitemap</h4>
      <ul class="space-y-2 leading-relaxed">
        {
          sitemapLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-text-body hover:text-accent transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h4 class="font-mono text-xs uppercase tracking-widest text-text-muted mb-3">Folgen</h4>
      <ul class="space-y-2 leading-relaxed">
        {
          followLinks.map((link) =>
            link.external ? (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener"
                  class="text-text-body hover:text-accent transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ) : (
              <li>
                <a
                  href={link.href}
                  class="text-text-body hover:text-accent transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ),
          )
        }
      </ul>
    </div>

    <div>
      <h4 class="font-mono text-xs uppercase tracking-widest text-text-muted mb-3">Rechtliches</h4>
      <ul class="space-y-2 leading-relaxed">
        {
          legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-text-body hover:text-accent transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div
    class="border-t border-line mt-8 pt-3 flex justify-between font-mono text-xs text-text-trace"
  >
    <span>© {year} guer</span>
    <span>v 0.1</span>
  </div>
</footer>
