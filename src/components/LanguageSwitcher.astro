---
import { getLangFromUrl, languages, stripLangPrefix, type Lang } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const cleanPath = stripLangPrefix(Astro.url.pathname);

const links: Record<Lang, string> = {
  de: cleanPath,
  en: cleanPath === '/' ? '/en/' : `/en${cleanPath}`,
  tr: cleanPath === '/' ? '/tr/' : `/tr${cleanPath}`,
};

const codes = Object.keys(languages) as Lang[];
---

<div class="lang-switcher">
  {codes.map((code) => (
    <a
      href={links[code]}
      class:list={['lang-link', lang === code ? 'is-active' : '']}
      data-lang={code}
      aria-current={lang === code ? 'page' : undefined}
    >
      {code.toUpperCase()}
    </a>
  ))}
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .lang-link {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--color-text-faint);
    text-decoration: none;
    padding: 0.375rem 0.4rem;
    transition: color 200ms ease;
    line-height: 1;
  }

  .lang-link:hover,
  .lang-link:focus-visible {
    color: var(--color-text-secondary);
    outline: none;
  }

  .lang-link.is-active {
    color: var(--color-text-primary);
  }

  @media (min-width: 768px) {
    .lang-switcher {
      gap: 0.375rem;
    }
    .lang-link {
      font-size: 11px;
      padding: 0.5rem 0.5rem;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.lang-link').forEach((link) => {
    link.addEventListener('click', () => {
      const lang = link.dataset.lang;
      if (lang) {
        try {
          localStorage.setItem('iamguer_lang', lang);
        } catch (e) {
          // ignore storage errors
        }
      }
    });
  });
</script>
