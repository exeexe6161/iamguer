---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Splash from '../../components/Splash.astro';
import PreviewSwitcher from '../../components/PreviewSwitcher.astro';
import { loadInstagramPosts, displaySrc, shortCaption } from '../../lib/instagram';

const payload = loadInstagramPosts();
const allPosts = payload?.posts ?? [];
const slides = allPosts.slice(0, 7);

const dateFmt = new Intl.DateTimeFormat('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const slideData = slides.map((p) => ({
  src: displaySrc(p),
  permalink: p.permalink,
  caption: shortCaption(p.caption, 220),
  date: dateFmt.format(new Date(p.timestamp)),
}));
---

<BaseLayout
  title="Preview — Cinematic"
  description="Vorschau Konzept 1: Cinematic Slideshow"
  currentPath="/preview/cinematic"
  noIndex={true}
>
  <Fragment slot="head-extra">
    <script is:inline>
      (function () {
        try {
          var url = new URL(window.location.href);
          var skip = url.searchParams.get('skip') === '1';
          var seen = sessionStorage.getItem('iamguer_splash_seen') === '1';
          if (skip || seen) {
            document.documentElement.classList.add('splash-skip');
          } else {
            document.documentElement.classList.add('splash-show');
          }
        } catch (e) {
          document.documentElement.classList.add('splash-show');
        }
      })();
    </script>
    <link
      rel="preload"
      href="/splash/portrait-pool.avif"
      as="image"
      type="image/avif"
      fetchpriority="high"
    />
  </Fragment>

  <Splash />
  <PreviewSwitcher current="cinematic" />

  {
    slideData.length === 0 ? (
      <section class="bg-canvas px-7 py-32 md:py-48 text-center min-h-[60vh] flex items-center justify-center">
        <p class="font-mono text-xs uppercase tracking-widest text-text-muted">
          Cinematic-Slideshow zeigt sich, sobald Instagram-Posts geladen sind.
        </p>
      </section>
    ) : (
      <section
        class="cinematic-hero"
        aria-roledescription="carousel"
        aria-label="Cinematic Slideshow"
        data-slide-count={slideData.length}
      >
        <div class="slides">
          {slideData.map((slide, i) => (
            <a
              class:list={['slide', i === 0 ? 'is-active' : '']}
              data-slide-index={i}
              href={slide.permalink}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={slide.caption || 'Foto auf Instagram öffnen'}
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              <img
                src={slide.src}
                alt={slide.caption || 'Fotografie von Hakan / iamguer'}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                fetchpriority={i === 0 ? 'high' : 'auto'}
              />
            </a>
          ))}
        </div>

        <div class="vignette" aria-hidden="true"></div>

        <div class="caption" aria-live="polite">
          {slideData.map((slide, i) => (
            <div
              class:list={['caption-item', i === 0 ? 'is-active' : '']}
              data-caption-index={i}
            >
              {slide.caption && <p class="caption-text">{slide.caption}</p>}
              <p class="caption-date">{slide.date}</p>
            </div>
          ))}
        </div>

        <button
          type="button"
          class="nav-arrow nav-prev"
          aria-label="Vorheriges Bild"
          data-cinematic-prev
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button
          type="button"
          class="nav-arrow nav-next"
          aria-label="Nächstes Bild"
          data-cinematic-next
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>

        <div class="dots" role="tablist" aria-label="Bild auswählen">
          {slideData.map((_, i) => (
            <button
              type="button"
              class:list={['dot', i === 0 ? 'is-active' : '']}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Bild ${i + 1} von ${slideData.length}`}
              data-dot-index={i}
            ></button>
          ))}
        </div>

        <div class="scroll-hint" aria-hidden="true" data-cinematic-scrollhint>
          <span>scroll</span>
          <span class="scroll-arrow">↓</span>
        </div>
      </section>
    )
  }

  <section class="bg-canvas py-[60vh] flex items-center justify-center px-7 reveal">
    <a
      href="/galerien"
      class="inline-flex items-baseline gap-3 text-text-secondary hover:text-text-primary transition-colors"
      style="font-family: 'Inter Variable', system-ui, sans-serif; font-weight: 200; font-size: 24px; letter-spacing: -0.01em;"
    >
      Mehr unter Galerien
      <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>

<style>
  .cinematic-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: #000;
  }

  .slides {
    position: absolute;
    inset: 0;
  }

  .slide {
    position: absolute;
    inset: 0;
    display: block;
    opacity: 0;
    transition: opacity 1200ms ease;
    pointer-events: none;
  }

  .slide.is-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .vignette {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background:
      radial-gradient(120% 80% at 50% 30%, rgba(0,0,0,0) 35%, rgba(0,0,0,0.45) 100%),
      linear-gradient(180deg, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.0) 25%, rgba(0,0,0,0.0) 60%, rgba(0,0,0,0.85) 100%);
  }

  .caption {
    position: absolute;
    bottom: 48px;
    left: 48px;
    z-index: 5;
    max-width: 60ch;
    pointer-events: none;
  }

  .caption-item {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 600ms ease, transform 600ms ease;
  }

  .caption-item.is-active {
    opacity: 1;
    transform: translateY(0);
    position: relative;
  }

  .caption-text {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 300;
    font-size: 14px;
    line-height: 1.6;
    color: #f5f1eb;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
    margin: 0 0 8px 0;
  }

  .caption-date {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 241, 235, 0.65);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
    margin: 0;
  }

  .nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    color: #fff;
    opacity: 0.6;
    cursor: pointer;
    transition: opacity 200ms ease, transform 200ms ease;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  .nav-arrow:hover,
  .nav-arrow:focus-visible {
    opacity: 1;
    outline: none;
  }

  .nav-prev {
    left: 24px;
  }
  .nav-next {
    right: 24px;
  }

  .dots {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 32px;
    z-index: 5;
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid rgba(245, 241, 235, 0.55);
    padding: 0;
    cursor: pointer;
    transition: background 200ms ease, transform 200ms ease, border-color 200ms ease;
  }

  .dot:hover {
    transform: scale(1.2);
    border-color: var(--color-text-primary);
  }

  .dot.is-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .scroll-hint {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 80px;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(245, 241, 235, 0.65);
    pointer-events: none;
    transition: opacity 400ms ease;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  .scroll-hint.is-hidden {
    opacity: 0;
  }

  .scroll-arrow {
    animation: scrollPulse 2.4s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { transform: translateY(0); opacity: 0.65; }
    50% { transform: translateY(4px); opacity: 1; }
  }

  /* Reveal sections */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 800ms cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 800ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .caption {
      bottom: 96px;
      left: 24px;
      right: 24px;
      max-width: none;
    }
    .nav-prev { left: 12px; }
    .nav-next { right: 12px; }
    .dots { bottom: 56px; }
    .scroll-hint { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .slide {
      transition: none;
    }
    .caption-item {
      transition: none;
      transform: none;
    }
    .scroll-arrow {
      animation: none;
    }
    .reveal {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var hero = document.querySelector('.cinematic-hero');
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Reveal-on-scroll for sections beyond the hero
    var revealNodes = document.querySelectorAll('.reveal');
    if (revealNodes.length && 'IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      revealNodes.forEach(function (n) { io.observe(n); });
    } else {
      revealNodes.forEach(function (n) { n.classList.add('is-visible'); });
    }

    if (!hero) return;

    var slides = hero.querySelectorAll('.slide');
    var captions = hero.querySelectorAll('.caption-item');
    var dots = hero.querySelectorAll('.dot');
    var scrollHint = hero.querySelector('[data-cinematic-scrollhint]');
    var prevBtn = hero.querySelector('[data-cinematic-prev]');
    var nextBtn = hero.querySelector('[data-cinematic-next]');
    var total = slides.length;
    if (total <= 1) {
      if (prevBtn) prevBtn.hidden = true;
      if (nextBtn) nextBtn.hidden = true;
    }
    var current = 0;
    var paused = false;
    var timerId = null;
    var INTERVAL = 6000;

    function show(index) {
      var next = ((index % total) + total) % total;
      if (next === current) return;
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      slides[next].classList.add('is-active');
      slides[next].setAttribute('aria-hidden', 'false');

      captions[current].classList.remove('is-active');
      captions[next].classList.add('is-active');

      dots[current].classList.remove('is-active');
      dots[current].setAttribute('aria-selected', 'false');
      dots[next].classList.add('is-active');
      dots[next].setAttribute('aria-selected', 'true');

      current = next;
    }

    function next() { show(current + 1); }
    function prev() { show(current - 1); }

    function startTimer() {
      if (reduceMotion) return;
      stopTimer();
      timerId = window.setInterval(function () {
        if (!paused && document.visibilityState === 'visible') next();
      }, INTERVAL);
    }
    function stopTimer() {
      if (timerId !== null) {
        window.clearInterval(timerId);
        timerId = null;
      }
    }

    if (prevBtn) prevBtn.addEventListener('click', function (e) {
      e.preventDefault();
      prev();
      startTimer();
    });
    if (nextBtn) nextBtn.addEventListener('click', function (e) {
      e.preventDefault();
      next();
      startTimer();
    });

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var idx = parseInt(dot.getAttribute('data-dot-index') || '0', 10);
        show(idx);
        startTimer();
      });
    });

    hero.addEventListener('mouseenter', function () { paused = true; });
    hero.addEventListener('mouseleave', function () { paused = false; });

    // Hide scroll hint once user scrolls
    if (scrollHint) {
      var hideHint = function () {
        if (window.scrollY > 8) {
          scrollHint.classList.add('is-hidden');
          window.removeEventListener('scroll', hideHint);
        }
      };
      window.addEventListener('scroll', hideHint, { passive: true });
    }

    // Keyboard
    document.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowRight') { next(); startTimer(); }
      if (e.key === 'ArrowLeft') { prev(); startTimer(); }
    });

    if (!reduceMotion) startTimer();
  })();
</script>
