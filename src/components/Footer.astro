---
import BrandMark from './BrandMark.astro';
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

const year = new Date().getFullYear();

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const sitemapLinks = [
  { href: localizedPath('/galerien', lang), label: t('nav.galerien') },
  { href: localizedPath('/kontakt', lang), label: t('nav.kontakt') },
];

const followLinks = [
  { href: 'https://instagram.com/iamguer', label: t('footer.instagram'), external: true },
];

const legalLinks = [
  { href: localizedPath('/impressum', lang), label: t('footer.impressum') },
  { href: localizedPath('/datenschutz', lang), label: t('footer.datenschutz') },
];
---

<footer class="border-t border-line px-7 pt-8 pb-4 mt-16">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <h4 class="font-mono text-xs uppercase tracking-widest text-text-muted mb-3">{t('footer.sitemap')}</h4>
      <ul class="space-y-2 leading-relaxed">
        {
          sitemapLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-text-body hover:text-accent transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h4 class="font-mono text-xs uppercase tracking-widest text-text-muted mb-3">{t('footer.follow')}</h4>
      <ul class="space-y-2 leading-relaxed">
        {
          followLinks.map((link) =>
            link.external ? (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener"
                  class="text-text-body hover:text-accent transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ) : (
              <li>
                <a
                  href={link.href}
                  class="text-text-body hover:text-accent transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ),
          )
        }
      </ul>
    </div>

    <div>
      <h4 class="font-mono text-xs uppercase tracking-widest text-text-muted mb-3">{t('footer.legal')}</h4>
      <ul class="space-y-2 leading-relaxed">
        {
          legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-text-body hover:text-accent transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-line mt-8 pt-3 flex font-mono text-xs text-text-trace">
    <span class="inline-flex items-center gap-2">© {year} <BrandMark size={24} wordmark /></span>
  </div>
</footer>
