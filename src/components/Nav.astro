---
import BrandMark from './BrandMark.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import {
  getLangFromUrl,
  useTranslations,
  stripLangPrefix,
  localizedPath,
} from '../i18n/utils';

interface Props {
  currentPath?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cleanPath = stripLangPrefix(Astro.url.pathname);

const navItems = [
  { dePath: '/', label: t('nav.index') },
  { dePath: '/galerien', label: t('nav.galerien') },
  { dePath: '/kontakt', label: t('nav.kontakt') },
];

function isActive(dePath: string): boolean {
  if (dePath === '/') return cleanPath === '/';
  return cleanPath === dePath || cleanPath.startsWith(dePath + '/');
}
---

<nav class="grid grid-cols-3 items-center px-7 py-5 border-b border-line">
  <a
    href={localizedPath('/', lang)}
    class="justify-self-start text-lg tracking-tight text-text-primary"
  >
    <BrandMark />
  </a>

  <ul
    class="hidden md:flex items-center gap-6 lg:gap-8 font-mono text-xs uppercase tracking-widest justify-self-center"
  >
    {
      navItems.map((item) => (
        <li>
          <a
            href={localizedPath(item.dePath, lang)}
            class:list={[
              'transition-colors hover:text-text-primary',
              isActive(item.dePath) ? 'text-text-primary' : 'text-text-muted',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="flex items-center gap-2 md:gap-4 justify-self-end">
    <LanguageSwitcher />
    <button
      type="button"
      id="navMobileToggle"
      aria-label={t('nav.menuOpen')}
      aria-expanded="false"
      aria-controls="navMobileMenu"
      class="md:hidden flex flex-col items-end justify-center gap-1.5 min-w-[44px] min-h-[44px]"
    >
      <span class="block h-px w-[18px] bg-text-primary"></span>
      <span class="block h-px w-[18px] bg-text-primary"></span>
      <span class="block h-px w-[18px] bg-text-primary"></span>
    </button>
  </div>
</nav>

<div
  id="navMobileMenu"
  hidden
  aria-hidden="true"
  class="md:hidden fixed inset-0 z-50 bg-canvas flex flex-col"
>
  <div class="grid grid-cols-3 items-center px-7 py-5 border-b border-line">
    <button
      type="button"
      id="navMobileClose"
      aria-label={t('nav.menuClose')}
      class="justify-self-start min-w-[44px] min-h-[44px] flex items-center justify-center text-text-primary text-3xl leading-none"
    >
      <span aria-hidden="true">×</span>
    </button>
    <span class="justify-self-center text-lg tracking-tight text-text-primary">iamguer</span>
    <div class="justify-self-end">
      <LanguageSwitcher />
    </div>
  </div>
  <ul
    class="flex-1 flex flex-col items-center justify-center gap-6 font-sans text-3xl tracking-tight font-light"
  >
    {
      navItems.map((item) => (
        <li>
          <a
            href={localizedPath(item.dePath, lang)}
            class:list={[
              'block transition-colors hover:text-text-primary',
              isActive(item.dePath) ? 'text-text-primary' : 'text-text-muted',
            ]}
            data-nav-mobile-link
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<style>
  #navMobileMenu {
    opacity: 0;
    transition: opacity 200ms ease;
  }
  #navMobileMenu.is-open {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    #navMobileMenu {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.getElementById('navMobileToggle');
    var menu = document.getElementById('navMobileMenu');
    var closeBtn = document.getElementById('navMobileClose');
    if (!toggle || !menu) return;

    var reduceMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    function open() {
      menu.hidden = false;
      void menu.offsetHeight;
      menu.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
      menu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      if (closeBtn) closeBtn.focus();
    }

    function close() {
      menu.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      var delay = reduceMotion ? 0 : 200;
      setTimeout(function () {
        menu.hidden = true;
      }, delay);
      toggle.focus();
    }

    toggle.addEventListener('click', open);
    if (closeBtn) closeBtn.addEventListener('click', close);

    var links = menu.querySelectorAll('[data-nav-mobile-link]');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', close);
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !menu.hidden) close();
    });
  })();
</script>
