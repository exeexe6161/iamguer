---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const labelMap = {
  de: 'Theme wechseln',
  en: 'Toggle theme',
  tr: 'Temayı değiştir',
} as const;

const ariaLabel = labelMap[lang] ?? labelMap.en;
const labelToLight = t('theme.toggleToLight');
const labelToDark = t('theme.toggleToDark');
---

<button
  type="button"
  class="theme-pill"
  aria-label={ariaLabel}
  data-theme-toggle
>
  <svg
    class="theme-pill__icon theme-pill__icon--sun"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <svg
    class="theme-pill__icon theme-pill__icon--moon"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
  <span class="theme-pill__label theme-pill__label--toLight">{labelToLight}</span>
  <span class="theme-pill__label theme-pill__label--toDark">{labelToDark}</span>
</button>

<style>
  .theme-pill {
    background: var(--color-line);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 6px 12px;
    color: var(--color-text-primary);
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: background-color 200ms ease, color 200ms ease;
    line-height: 1;
    white-space: nowrap;
  }

  .theme-pill:hover,
  .theme-pill:focus-visible {
    background: var(--color-line-strong);
    outline: none;
  }

  .theme-pill__icon {
    display: none;
    flex-shrink: 0;
  }

  .theme-pill__label {
    letter-spacing: 0.04em;
  }

  .theme-pill__icon--sun,
  .theme-pill__label--toLight {
    display: inline-block;
  }

  .theme-pill__icon--moon,
  .theme-pill__label--toDark {
    display: none;
  }

  :global([data-theme='light']) .theme-pill__icon--sun,
  :global([data-theme='light']) .theme-pill__label--toLight {
    display: none;
  }

  :global([data-theme='light']) .theme-pill__icon--moon {
    display: inline-block;
  }

  :global([data-theme='light']) .theme-pill__label--toDark {
    display: inline-block;
  }

  @media (max-width: 767px) {
    .theme-pill {
      padding: 5px 10px;
      font-size: 10px;
      gap: 6px;
    }
    .theme-pill__icon {
      width: 12px;
      height: 12px;
    }
  }
</style>

<script>
  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement | null;
    const btn = target?.closest<HTMLElement>('[data-theme-toggle]');
    if (!btn) return;
    const current =
      document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem('iamguer_theme', next);
    } catch {
      // ignore storage errors
    }
  });
</script>
