---
import BrandMark from './BrandMark.astro';
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const menuLabelMap = { de: 'Menü', en: 'Menu', tr: 'Menü' } as const;
const menuLabel = menuLabelMap[lang] ?? menuLabelMap.en;
---

<div
  id="siteMenuOverlay"
  class="menu-overlay"
  data-menu-overlay
  hidden
  aria-hidden="true"
>
  <div class="menu-overlay__topbar">
    <a
      href={localizedPath('/', lang)}
      class="menu-overlay__logo"
      aria-label="iamguer"
    >
      <BrandMark />
    </a>
    <button
      type="button"
      class="menu-overlay__close"
      aria-label={t('nav.menuClose')}
      data-menu-close
    >
      <span aria-hidden="true">×</span>
    </button>
    <span class="menu-overlay__spacer" aria-hidden="true"></span>
  </div>

  <div class="menu-overlay__inner">
    <nav class="menu-overlay__nav" aria-label={menuLabel}>
      <a href={localizedPath('/', lang)} class="menu-pill">
        <span>{t('nav.home')}</span>
        <span class="menu-pill__arrow" aria-hidden="true">↗</span>
      </a>
      <a href={localizedPath('/galerien', lang)} class="menu-pill">
        <span>{t('nav.galerien')}</span>
        <span class="menu-pill__arrow" aria-hidden="true">↗</span>
      </a>
      <a href={localizedPath('/kontakt', lang)} class="menu-pill">
        <span>{t('nav.kontakt')}</span>
        <span class="menu-pill__arrow" aria-hidden="true">↗</span>
      </a>
    </nav>
  </div>
</div>

<style>
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: var(--color-canvas);
    color: var(--color-text-primary);
    transform: translateY(-100%);
    transition: transform 600ms cubic-bezier(0.7, 0, 0.2, 1);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .menu-overlay[hidden] {
    display: none;
  }

  .menu-overlay.is-open {
    transform: translateY(0);
  }

  .menu-overlay__topbar {
    position: sticky;
    top: 0;
    z-index: 2;
    background: var(--color-canvas);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-line);
  }

  @media (min-width: 768px) {
    .menu-overlay__topbar {
      padding: 22px 28px;
    }
  }

  .menu-overlay__logo {
    color: var(--color-text-primary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-self: start;
  }

  .menu-overlay__close {
    background: none;
    border: none;
    color: var(--color-text-primary);
    font-size: 28px;
    font-weight: 300;
    line-height: 1;
    cursor: pointer;
    padding: 8px 12px;
    justify-self: center;
    transition: transform 300ms ease, opacity 300ms ease;
  }

  .menu-overlay__close:hover,
  .menu-overlay__close:focus-visible {
    transform: rotate(90deg);
    outline: none;
  }

  .menu-overlay__spacer {
    justify-self: end;
  }

  .menu-overlay__inner {
    padding: 30px 16px 50px;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (min-width: 800px) {
    .menu-overlay__inner {
      padding: 50px 28px 70px;
    }
  }

  .menu-overlay__nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
  }

  .menu-pill {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 24px;
    background: color-mix(in srgb, currentColor 6%, transparent);
    color: var(--color-text-primary);
    border: 1px solid color-mix(in srgb, currentColor 22%, transparent);
    border-radius: 999px;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 400;
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease;
    -webkit-tap-highlight-color: transparent;
    transform: translateZ(0);
  }

  .menu-pill:hover,
  .menu-pill:focus-visible {
    background: color-mix(in srgb, currentColor 14%, transparent);
    border-color: color-mix(in srgb, currentColor 45%, transparent);
    outline: none;
  }

  .menu-pill__arrow {
    font-size: 13px;
    line-height: 0;
    opacity: 0.7;
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-overlay {
      transition: opacity 300ms ease;
      transform: none;
      opacity: 0;
    }
    .menu-overlay.is-open {
      transform: none;
      opacity: 1;
    }
    .menu-overlay__close {
      transition: none;
    }
    .menu-overlay__close:hover,
    .menu-overlay__close:focus-visible {
      transform: none;
    }
  }
</style>

<script>
  let cleanup = null;
  let lastTrigger = null;
  let hideTimer = null;
  const reduceMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;
  const slideMs = reduceMotion ? 300 : 600;

  function setTriggersExpanded(isOpen) {
    const triggers = document.querySelectorAll('[data-menu-open]');
    for (let i = 0; i < triggers.length; i++) {
      triggers[i].setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    }
  }

  function openMenu(trigger) {
    const overlay = document.getElementById('siteMenuOverlay');
    if (!overlay) return;
    if (hideTimer) {
      clearTimeout(hideTimer);
      hideTimer = null;
    }
    lastTrigger = trigger || null;
    overlay.hidden = false;
    // force reflow so transition runs from initial state
    void overlay.offsetHeight;
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTriggersExpanded(true);
    const closeBtn = overlay.querySelector('[data-menu-close]');
    if (closeBtn) closeBtn.focus();
  }

  function closeMenu() {
    const overlay = document.getElementById('siteMenuOverlay');
    if (!overlay) return;
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTriggersExpanded(false);
    if (hideTimer) clearTimeout(hideTimer);
    hideTimer = setTimeout(() => {
      overlay.hidden = true;
      hideTimer = null;
    }, slideMs);
    if (lastTrigger) {
      try {
        lastTrigger.focus();
      } catch (e) {
        // ignore focus errors
      }
      lastTrigger = null;
    }
  }

  function clickHandler(e) {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const openBtn = target.closest('[data-menu-open]');
    if (openBtn) {
      e.preventDefault();
      const overlay = document.getElementById('siteMenuOverlay');
      if (overlay && overlay.classList.contains('is-open')) {
        closeMenu();
      } else {
        openMenu(openBtn);
      }
      return;
    }
    const closeBtn = target.closest('[data-menu-close]');
    if (closeBtn) {
      e.preventDefault();
      closeMenu();
    }
  }

  function keydownHandler(e) {
    const overlay = document.getElementById('siteMenuOverlay');
    if (e.key === 'Escape' && overlay && overlay.classList.contains('is-open')) {
      closeMenu();
    }
  }

  function init() {
    if (cleanup) cleanup();
    document.addEventListener('click', clickHandler);
    document.addEventListener('keydown', keydownHandler);
    cleanup = () => {
      document.removeEventListener('click', clickHandler);
      document.removeEventListener('keydown', keydownHandler);
    };
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
