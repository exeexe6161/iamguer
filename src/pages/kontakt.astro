---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontakt" currentPath="/kontakt">
  <section class="px-7 py-16 max-w-4xl mx-auto">
    <h1 class="font-serif text-text-primary text-5xl">Kontakt</h1>
    <p class="text-text-secondary mt-4">
      Schreib mir gerne. Formular kommt bald — bis dahin direkt:
      <a href="mailto:hello@guer.de" class="text-accent">hello@guer.de</a>
    </p>
  </section>
</BaseLayout>
